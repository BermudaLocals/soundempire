# Sound Empire Environment Variables
# Copy to .env and fill in your values

# Database (Neon PostgreSQL)
DATABASE_URL=

# AI Service (Anthropic Claude - direct, primary)
ANTHROPIC_API_KEY=

# AI Service (OpenRouter - optional alternative)
# OPENROUTER_API_KEY=

# Server Port (Railway auto-injects this)
PORT=3001

# Environment
NODE_ENV=production

# Optional: For future integrations
# ELEVENLABS_API_KEY=
# KLING_API_KEY=
# RUNWARE_API_KEY=
# SUNO_API_KEY=
